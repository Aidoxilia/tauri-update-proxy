# Personal Access Token GitHub (fine-grained), scope: Contents = Read-only
# sur le repo privé uniquement (pas besoin de plus)
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Propriétaire et nom du dépôt privé
GITHUB_OWNER=ton-user-ou-org
GITHUB_REPO=DoEverything

# Clé secrète partagée entre ce proxy et l'app Tauri (génère une longue chaîne random)
API_KEY=remplace-moi-par-un-secret-long-et-aleatoire

# Optionnel
PORT=8080
CACHE_TTL_SECONDS=60
